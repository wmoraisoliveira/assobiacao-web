{
  "hosting": {
    "site": "assobiacao-2758a",
    "public": ".",
    "ignore": ["firebase.json", ".firebaserc", ".git", "README.md", "CNAME", "node_modules"],
    "cleanUrls": true,
    "rewrites": [
      {
        "source": "/v/**",
        "function": "video_preview",
        "region": "us-central1"
      }
    ],
    "headers": [
      {
        "source": "**",
        "headers": [{ "key": "Cache-Control", "value": "public, max-age=300, stale-while-revalidate=3600" }]
      },
      {
        "source": "/assets/**",
        "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
      }
    ]
  }
}
